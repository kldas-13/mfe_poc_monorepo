{
  "name": "graph-canvas",
  "version": "1.0.0",
  "description": "Graph Canvas — independent repo with its own BFF (:3001) and MFE (:5174). Graphology is the client-side graph store. Sigma.js renders it. qiankun exposes the MFE to the meta-shell.",
  "type": "module",
  "scripts": {
    "dev":       "concurrently -n BFF,MFE -c cyan,green \"npm run dev:bff\" \"npm run dev:mfe\"",
    "dev:bff":   "tsx --watch bff.ts",
    "dev:mfe":   "vite --port 5174 --host",
    "build:mfe": "vite build",
    "preview":   "vite preview --port 5174 --host",
    "start:bff": "tsx bff.ts"
  },
  "dependencies": {
    "graphology":                    "^0.25.4",
    "graphology-layout":             "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "sigma":                         "^2.4.0",
    "vite-plugin-qiankun":           "^1.0.14"
  },
  "devDependencies": {
    "@fastify/cors":      "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "@types/node":        "^20.11.5",
    "concurrently":       "^8.2.2",
    "fastify":            "^4.26.2",
    "tsx":                "^4.7.1",
    "typescript":         "^5.3.3",
    "vite":               "^5.1.3"
  },
  "engines": { "node": ">=18" }
}
