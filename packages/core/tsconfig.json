{
    "compilerOptions": {
        "module": "esnext",
        "target": "esnext",
        "lib": ["esnext", "DOM"],
        "declaration": true,
        "strict": true,
        "moduleResolution": "node",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "noImplicitAny": true,
        "allowJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "stripInternal": true,
        "types": ["node"]
    },
    "include": ["src"]
}
