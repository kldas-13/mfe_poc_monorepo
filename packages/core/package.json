{
    "name": "@meta-ux/core",
    "version": "1.0.0",
    "private": false,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint src"
    },
    "dependencies": {
        "@meta-ux/shared": "workspace:*",
        "@meta-ux/types": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^25.4.0",
        "tsup": "^8.0.0",
        "typescript": "^5.5.3"
    }
}
